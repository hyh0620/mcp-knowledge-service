# MCP Knowledge Service local configuration.
# Copy to .env for local development. Do not commit .env.

# Fill this value locally before real embedding or provider-backed ingestion. Do not commit it.
# 真实执行 embedding 或 Provider 驱动的 ingestion 前，在本地填入该值；不要提交到 Git。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
